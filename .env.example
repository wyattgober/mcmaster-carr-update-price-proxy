# Proxy auth – required for /api/mcmaster/* endpoints
PROXY_API_KEY=

# McMaster API credentials
MCMASTER_USERNAME=
MCMASTER_PASSWORD=
MCMASTER_CERT_PASSWORD=

# Certificate: provide one of the two (base64 preferred on Vercel)
MCMASTER_CERT_BASE64=
MCMASTER_CERT_PATH=./Certificates/certificate.pfx

# McMaster API (optional – defaults shown)
MCMASTER_API_HOST=api.mcmaster.com
MCMASTER_API_BASE_PATH=/v1
MCMASTER_REQUEST_TIMEOUT_MS=15000
# Set to false if you get "unable to verify the first certificate" (e.g. chain not in trust store)
MCMASTER_TLS_REJECT_UNAUTHORIZED=true

# Logging
LOG_LEVEL=info
